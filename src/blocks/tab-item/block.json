{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "gab/tab-item",
    "version": "1.0.0",
    "title": "GAB Tab Item",
    "category": "layout",
    "description": "Un panneau individuel d'un onglet.",
    "textdomain": "gab",
    "parent": [ "gab/tabs" ],
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css",
    "attributes": {
        "label": {
            "type": "string",
            "default": "Onglet"
        },
        "content": {
            "type": "string",
            "default": ""
        }
    },
    "supports": {
        "html": false
    }
}