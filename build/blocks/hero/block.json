{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gab/hero",
  "version": "1.0.0",
  "title": "GAB Hero",
  "category": "layout",
  "description": "Un bloc Hero avec titre, sous-titre et image de fond.",
  "textdomain": "gab",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "title": {
      "type": "string",
      "default": "Votre titre ici"
    },
    "subtitle": {
      "type": "string",
      "default": "Votre sous-titre ici"
    },
    "backgroundUrl": {
      "type": "string",
      "default": ""
    },
    "backgroundId": {
      "type": "number",
      "default": 0
    },
    "minHeight": {
      "type": "number",
      "default": 500
    },
    "overlayOpacity": {
      "type": "number",
      "default": 40
    },
    "textAlign": {
      "type": "string",
      "default": "center"
    }
  },
  "supports": {
    "html": false,
    "align": [
      "full",
      "wide"
    ]
  }
}